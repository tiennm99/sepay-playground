# SePay credentials (from https://my.sepay.vn/)
SEPAY_WEBHOOK_API_KEY=replace-me-with-webhook-key
SEPAY_ACCOUNT_NUMBER=0010000000000
SEPAY_BANK_CODE=Vietcombank
# Order code prefix — MUST match the prefix configured in SePay dashboard
# (Company Settings → General Configuration). Used as both QR memo prefix
# and the regex anchor when SePay can't auto-extract `code`.
SEPAY_ORDER_PREFIX=SEVQR

# Upstash Redis — accepts either UPSTASH_REDIS_REST_* (vanilla Upstash) or
# KV_REST_API_* (Vercel Marketplace alias). KEY_PREFIX namespaces every key so
# this playground can share one Upstash DB with the rest of the portfolio.
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me
KV_REST_API_URL=
KV_REST_API_TOKEN=
KEY_PREFIX=sepay-playground:

# Dev-only header to gate /api/dev/simulate-webhook on non-PROD deployments
# (e.g. Vercel preview is technically !PROD and publicly reachable).
# Generate any random string; only required in non-prod.
DEV_SIMULATE_TOKEN=local-dev-only
